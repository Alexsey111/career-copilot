TEST_DATABASE_URL=postgresql+psycopg://career_user:career_pass@localhost:5432/career_copilot_test

SENTRY_DSN=
OPENAI_API_KEY=

JWT_SECRET_KEY=your-super-secret-key-change-in-prod
